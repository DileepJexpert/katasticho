# ──────────────────────────────────────────────────────────────
# Katasticho ERP — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Database (PostgreSQL 16) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=katasticho
DB_USER=katasticho
DB_PASSWORD=          # REQUIRED — generate a strong password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=       # Optional — leave empty for local dev

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=           # REQUIRED — min 256 bits, e.g. openssl rand -base64 64
JWT_ACCESS_EXPIRY=15  # minutes
JWT_REFRESH_EXPIRY=7  # days

# ── AI (Anthropic Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=    # Optional — enables AI chat features

# ── Email (Production: Resend / SES / SMTP) ──────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=        # API key from Resend / SES

# ── WhatsApp Business (future) ───────────────────────────────
WHATSAPP_BUSINESS_API_KEY=

# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── Flutter Web (Vercel build-time) ──────────────────────────
API_BASE_URL=https://api.katasticho.com
SENTRY_DSN=           # Optional — Sentry error tracking DSN
