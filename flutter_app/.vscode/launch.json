{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DEV (local backend)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=ENV=dev"
      ]
    },
    {
      "name": "DEV (custom API URL)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=ENV=dev",
        "--dart-define=API_BASE_URL=http://192.168.1.100:8080"
      ]
    },
    {
      "name": "Staging",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=ENV=staging"
      ]
    },
    {
      "name": "Production (debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=ENV=prod"
      ]
    },
    {
      "name": "Production (release)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "args": [
        "--dart-define=ENV=prod"
      ]
    }
  ]
}
