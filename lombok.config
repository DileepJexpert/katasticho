# Stop Lombok from looking further up the directory tree.
config.stopBubbling = true

# Tell Lombok to copy these annotations from fields onto the
# generated constructor parameters. Without this, `@Lazy` on a
# `private final` field is dropped by `@RequiredArgsConstructor`
# and Spring resolves the bean eagerly — breaking circular
# references that we intentionally wire through a proxy.
#
# Affected today: ItemService ↔ ItemGroupService (F5 matrix
# bulk-create routes each child create back through ItemService,
# and ItemService asks ItemGroupService for the group's defaults
# on normal creates).
lombok.copyableAnnotations += org.springframework.context.annotation.Lazy
